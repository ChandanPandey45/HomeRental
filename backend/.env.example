# Server Configuration
PORT=5000
NODE_ENV=development

# Firebase Configuration
# Download your service account key from Firebase Console
# Place the file as serviceAccountKey.json in the backend directory
# OR encode the JSON and paste it below
FIREBASE_SERVICE_ACCOUNT_JSON={}

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# Payment Gateway (Optional - for Stripe/PayPal integration)
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# AWS Configuration (Optional - for image hosting)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
